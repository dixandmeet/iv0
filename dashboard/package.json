{
  "name": "aule-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti :3001 | xargs kill -9 2>/dev/null; sleep 1; rm -rf .next && next dev --port 3001",
    "dev:clean": "lsof -ti :3001 | xargs kill -9 2>/dev/null; sleep 1; rm -rf .next && next dev --port 3001",
    "dev:fresh": "lsof -ti :3001 | xargs kill -9 2>/dev/null; sleep 1; rm -rf .next node_modules/.cache && next dev --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "maplibre-gl": "^5.6.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.79.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.185.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.28.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.0"
  }
