{
  "name": "wazibus-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti :3001 | xargs kill -9 2>/dev/null; sleep 1; rm -rf .next && next dev --port 3001",
    "dev:clean": "lsof -ti :3001 | xargs kill -9 2>/dev/null; sleep 1; rm -rf .next && next dev --port 3001",
    "dev:fresh": "lsof -ti :3001 | xargs kill -9 2>/dev/null; sleep 1; rm -rf .next node_modules/.cache && next dev --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "maplibre-gl": "^5.6.0",
    "next": "^15.5.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.0"
  }
}
