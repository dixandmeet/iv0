NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Optionnel — contourne RLS pour l'admin et les invitations conducteur.
# Sans cette clé, l'admin utilise la session authentifiée (après migration RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optionnel — autocomplete d'adresses via Google Places (sinon repli sur Nominatim/OSM)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Optionnel — active les perturbations opérateur SIRI Situation Exchange.
# Clé de souscription du portail https://api.okina.fr (dataset NAOLIBORG).
NAOLIB_SIRI_API_KEY=your-okina-api-key

# Développement local uniquement. Ignoré par les builds de production.
NEXT_PUBLIC_ENABLE_DEMO_DATA=false
