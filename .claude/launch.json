{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "aule-web",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port", "5179"],
      "port": 5179
    },
    {
      "name": "aule-web-profile",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port", "5179", "--profile"],
      "port": 5179
    },
    {
      "name": "dashboard",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "dashboard", "run", "dev"],
      "port": 3001
    },
    {
      "name": "sae-web",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd SAE && flutter run -d web-server --web-port 5183"],
      "port": 5183
    }
  ]
}
